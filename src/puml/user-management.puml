@startuml

enum Role {
    ADMIN
    TEACHER
    STUDENT
}

enum UserStatus {
     ACTIVE
     INACTIVE
     SUSPENDED
}

class User {
    +int id
    +String first_name
    +String last_name
    +String email
    +String password
    +Role role
    +UserStatus status
    +SchoolClass schoolClass
}

class SchoolClass {
    +Long id
    +String name
    +String code
    +String level
    +Integer capacity
}

User "0..*" --> "0..1" SchoolClass : assigned to

note right of User
Role differentiates ADMIN / TEACHER / STUDENT.
Dedicated subclasses are optional and not required
for class assignment management.
end note

@enduml
