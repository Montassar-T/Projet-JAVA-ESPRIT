<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="600" prefWidth="1000" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.educlass.controller.MainController" style="-fx-padding: 0;">

    <!-- Barre latérale (design Projet-JAVA-ESPRIT) -->
    <left>
        <VBox fx:id="sidebar" prefWidth="240" spacing="0" style="-fx-background-color: #2c3e50;" VBox.vgrow="ALWAYS">
            <padding>
                <Insets top="20" right="15" bottom="20" left="15"/>
            </padding>

            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 30 5;">
                <SVGPath content="M12 3L1 9l11 6 9-4.91V17h2V9L12 3zM5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82z" fill="#3498db" scaleX="1.2" scaleY="1.2"/>
                <Label style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" text="EduClass" />
            </HBox>
            <Label style="-fx-text-fill: #bdc3c7; -fx-font-size: 11px;" text="Espace étudiant" />

            <!-- Infos utilisateur -->
            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 10 0 25 5;">
                <StackPane>
                    <Circle fx:id="avatarCircle" fill="#3498db" radius="20" />
                    <Label fx:id="initialsLabel" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;" />
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="nameLabel" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px;" />
                    <Label fx:id="roleLabel" style="-fx-text-fill: #bdc3c7; -fx-font-size: 10px; -fx-text-transform: uppercase;" />
                </VBox>
            </HBox>

            <!-- Boutons de navigation -->
            <VBox spacing="6" VBox.vgrow="ALWAYS">
                <Button onAction="#showDashboard" minWidth="210" prefWidth="210" maxWidth="210" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-padding: 10 15; -fx-background-radius: 5;" text="Tableau de bord" onMouseEntered="#hoverEnter" onMouseExited="#hoverExit">
                    <graphic>
                        <SVGPath content="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" fill="white" scaleX="0.9" scaleY="0.9"/>
                    </graphic>
                </Button>
                <Button onAction="#showCours" minWidth="210" prefWidth="210" maxWidth="210" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-padding: 10 15;" text="Matières" onMouseEntered="#hoverEnter" onMouseExited="#hoverExit">
                    <graphic>
                        <SVGPath content="M12 3L1 9l11 6 9-4.91V17h2V9L12 3z" fill="white" scaleX="0.9" scaleY="0.9"/>
                    </graphic>
                </Button>
                <Button onAction="#showMarks" minWidth="210" prefWidth="210" maxWidth="210" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-padding: 10 15;" text="Notes" onMouseEntered="#hoverEnter" onMouseExited="#hoverExit">
                    <graphic>
                        <SVGPath content="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14h-2V9h2v8zm4 0h-2v-4h2v4zm-8 0H8v-2h2v2z" fill="white" scaleX="0.9" scaleY="0.9"/>
                    </graphic>
                </Button>
                <Button onAction="#showEvaluations" minWidth="210" prefWidth="210" maxWidth="210" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-padding: 10 15;" text="Évaluations" onMouseEntered="#hoverEnter" onMouseExited="#hoverExit">
                    <graphic>
                        <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" fill="white" scaleX="0.9" scaleY="0.9"/>
                    </graphic>
                </Button>
                <Button onAction="#showChat" minWidth="210" prefWidth="210" maxWidth="210" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-padding: 10 15;" text="Messages" onMouseEntered="#hoverEnter" onMouseExited="#hoverExit">
                    <graphic>
                        <SVGPath content="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-2 12H6v-2h12v2zm0-3H6V9h12v2zm0-3H6V6h12v2z" fill="white" scaleX="0.9" scaleY="0.9"/>
                    </graphic>
                </Button>
                <Button fx:id="usersButton" onAction="#showUsers" minWidth="210" prefWidth="210" maxWidth="210" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-padding: 10 15;" text="Utilisateurs" onMouseEntered="#hoverEnter" onMouseExited="#hoverExit" visible="false" managed="false">
                    <graphic>
                        <SVGPath content="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5s-3 1.34-3 3 1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z" fill="white" scaleX="0.9" scaleY="0.9"/>
                    </graphic>
                </Button>
                <Button onAction="#showSettings" minWidth="210" prefWidth="210" maxWidth="210" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-padding: 10 15;" text="Paramètres" onMouseEntered="#hoverEnter" onMouseExited="#hoverExit">
                    <graphic>
                        <SVGPath content="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z" fill="white" scaleX="0.9" scaleY="0.9"/>
                    </graphic>
                </Button>
            </VBox>

            <!-- Déconnexion -->
            <VBox alignment="BOTTOM_CENTER" style="-fx-padding: 20 0 0 0;">
                <Button alignment="CENTER" onAction="#handleLogout" minWidth="210" prefHeight="40.0" prefWidth="210.0" maxWidth="210"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="Déconnexion">
                    <graphic>
                        <SVGPath content="M13 3h-2v10h2V3zm4.83 2.17l-1.42 1.42C17.99 7.86 19 9.81 19 12c0 3.87-3.13 7-7 7s-7-3.13-7-7c0-2.19 1.01-4.14 2.58-5.42L6.17 5.17C4.23 6.82 3 9.26 3 12c0 4.97 4.03 9 9 9s9-4.03 9-9c0-2.74-1.23-5.18-3.17-6.83z" fill="white" scaleX="0.8" scaleY="0.8"/>
                    </graphic>
                </Button>
            </VBox>

        </VBox>
    </left>

    <!-- RIGHT SECTION -->
    <center>
        <VBox prefWidth="780" spacing="0">

            <!-- Top Navbar -->
            <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 10;">
                <StackPane>
                    <Button fx:id="notificationButton" onAction="#toggleNotifications"
                            style="-fx-font-size: 18px; -fx-background-color: transparent; -fx-text-fill: black; -fx-cursor: hand;" text="🔔" />
                    <Label fx:id="notificationBadge" visible="false" managed="false"
                           style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 10px;
                                  -fx-font-weight: bold; -fx-padding: 1 5; -fx-background-radius: 8;
                                  -fx-min-width: 18; -fx-min-height: 18; -fx-alignment: center;"
                           StackPane.alignment="TOP_RIGHT"
                           translateX="-2" translateY="2" mouseTransparent="true" />
                </StackPane>
            </HBox>

            <!-- Content Render Area -->
            <StackPane fx:id="contentPane" style="-fx-background-color: #ecf0f1; -fx-padding: 20" VBox.vgrow="ALWAYS">
                <!-- Dynamic content will be loaded here -->
            </StackPane>

        </VBox>
    </center>

</BorderPane>

