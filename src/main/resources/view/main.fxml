<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="1100" prefWidth="1600" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.educlass.controller.MainController" style="-fx-padding: 0;">

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox prefWidth="240" spacing="0" style="-fx-background-color: #2c3e50;" VBox.vgrow="ALWAYS">
            <padding>
                <Insets top="20" right="15" bottom="20" left="15"/>
            </padding>

            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 30 5;">
                <SVGPath content="M12 3L1 9l11 6 9-4.91V17h2V9L12 3zM5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82z" fill="#3498db" scaleX="1.2" scaleY="1.2"/>
                <Label style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" text="EduClass" />
            </HBox>

            <!-- User Info (Optional in Sidebar if we have Top Header, but let's keep a compact one) -->
            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 10 0 25 5;">
                <StackPane>
                    <Circle fx:id="avatarCircle" fill="#3498db" radius="20" />
                    <Label fx:id="initialsLabel" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;" />
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="nameLabel" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px;" />
                    <Label fx:id="roleLabel" style="-fx-text-fill: #bdc3c7; -fx-font-size: 10px; -fx-text-transform: uppercase;" />
                </VBox>
            </HBox>

            <!-- Navigation Buttons -->
            <VBox spacing="6" VBox.vgrow="ALWAYS">
                <Button onAction="#showDashboard" prefWidth="210" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-padding: 10 15; -fx-background-radius: 5;" text="Dashboard" onMouseEntered="#hoverEnter" onMouseExited="#hoverExit">
                    <graphic>
                        <SVGPath content="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" fill="white" scaleX="0.9" scaleY="0.9"/>
                    </graphic>
                </Button>
                <Button onAction="#showCours" prefWidth="210" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-padding: 10 15;" text="Courses" onMouseEntered="#hoverEnter" onMouseExited="#hoverExit">
                    <graphic>
                        <SVGPath content="M12 3L1 9l11 6 9-4.91V17h2V9L12 3z" fill="white" scaleX="0.9" scaleY="0.9"/>
                    </graphic>
                </Button>
                <Button onAction="#showMarks" prefWidth="210" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-padding: 10 15;" text="Grades" onMouseEntered="#hoverEnter" onMouseExited="#hoverExit">
                    <graphic>
                        <SVGPath content="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14h-2V9h2v8zm4 0h-2v-4h2v4zm-8 0H8v-2h2v2z" fill="white" scaleX="0.9" scaleY="0.9"/>
                    </graphic>
                </Button>
                <Button onAction="#showEvaluations" prefWidth="210" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-padding: 10 15;" text="Assessments" onMouseEntered="#hoverEnter" onMouseExited="#hoverExit">
                    <graphic>
                        <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" fill="white" scaleX="0.9" scaleY="0.9"/>
                    </graphic>
                </Button>
                <Button onAction="#showSettings" prefWidth="210" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-padding: 10 15;" text="Settings" onMouseEntered="#hoverEnter" onMouseExited="#hoverExit">
                    <graphic>
                        <SVGPath content="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z" fill="white" scaleX="0.9" scaleY="0.9"/>
                    </graphic>
                </Button>
            </VBox>

            <!-- Logout Button -->
            <VBox alignment="BOTTOM_CENTER" style="-fx-padding: 20 0 0 0;">
                <Button alignment="CENTER" onAction="#handleLogout" prefHeight="40.0" prefWidth="210.0" 
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="Logout">
                    <graphic>
                        <SVGPath content="M13 3h-2v10h2V3zm4.83 2.17l-1.42 1.42C17.99 7.86 19 9.81 19 12c0 3.87-3.13 7-7 7s-7-3.13-7-7c0-2.19 1.01-4.14 2.58-5.42L6.17 5.17C4.23 6.82 3 9.26 3 12c0 4.97 4.03 9 9 9s9-4.03 9-9c0-2.74-1.23-5.18-3.17-6.83z" fill="white" scaleX="0.8" scaleY="0.8"/>
                    </graphic>
                </Button>
            </VBox>

        </VBox>
    </left>

    <!-- RIGHT SECTION -->
    <center>
        <VBox spacing="0">
            <!-- Top Header Bar -->
            <HBox alignment="CENTER_RIGHT" spacing="15" style="-fx-background-color: white; -fx-padding: 10 30; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 1);">
                <!-- Search bar placeholder -->
                <HBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <Label text="Welcome back, " style="-fx-font-size: 16px; -fx-text-fill: #7f8c8d;"/>
                    <Label fx:id="welcomeNameLabel" text="Student" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                </HBox>

                <!-- Notifications Toggle -->
                <StackPane>
                    <Button onAction="#toggleNotifications" style="-fx-background-color: #f3f4f6; -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 8;" text="">
                        <graphic>
                            <SVGPath content="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.89 2 2 2zm6-6v-5c0-3.07-1.64-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z" fill="#7f8c8d" />
                        </graphic>
                    </Button>
                    <Label fx:id="notificationBadge" text="0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 9px; -fx-padding: 1 5; -fx-background-radius: 10;" StackPane.alignment="TOP_RIGHT">
                        <StackPane.margin>
                            <Insets top="-2" right="-2"/>
                        </StackPane.margin>
                    </Label>
                </StackPane>
                
                <Rectangle width="1" height="25" fill="#dfe6e9"/>

                <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-cursor: hand;">
                    <StackPane>
                        <Circle fill="#f3f4f6" radius="16" />
                        <Label fx:id="headerInitialsLabel" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #7f8c8d;" />
                    </StackPane>
                </HBox>
            </HBox>

            <StackPane alignment="TOP_RIGHT">
                <VBox.margin>
                    <Insets right="30"/>
                </VBox.margin>
                
                <!-- Notification Dropdown -->
                <VBox fx:id="notificationDropdown" visible="false" managed="false" style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 15, 0, 0, 5); -fx-background-radius: 8; -fx-padding: 15;" maxWidth="300" maxHeight="450">
                    <Label text="Recent Notifications" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 0 0 10 0;"/>
                    <ListView fx:id="notificationListView" prefHeight="350" style="-fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #eee;"/>
                </VBox>
            </StackPane>

            <!-- Content Render Area -->
            <StackPane fx:id="contentPane" style="-fx-background-color: #f8f9fc; -fx-padding: 0" VBox.vgrow="ALWAYS">
                <!-- Dynamic content will be loaded here -->
            </StackPane>

        </VBox>
    </center>

</BorderPane>
