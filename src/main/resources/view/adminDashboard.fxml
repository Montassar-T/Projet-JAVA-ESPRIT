<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.SVGPath?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.educlass.controller.AdminDashboardController"
            prefWidth="1600" prefHeight="900"
            style="-fx-background-color: #ecf0f1; -fx-padding: 0;">

    <!-- Barre latérale (design Projet-JAVA-ESPRIT) - Espace superviseur -->
    <left>
        <VBox fx:id="sidebar" prefWidth="240" spacing="0" style="-fx-background-color: #2c3e50;" VBox.vgrow="ALWAYS">
            <padding>
                <Insets top="20" right="15" bottom="20" left="15"/>
            </padding>

            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 30 5;">
                <SVGPath content="M12 3L1 9l11 6 9-4.91V17h2V9L12 3zM5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82z" fill="#3498db" scaleX="1.2" scaleY="1.2"/>
                <Label style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" text="EduClass" />
            </HBox>
            <Label style="-fx-text-fill: #bdc3c7; -fx-font-size: 11px;" text="Espace superviseur" />

            <!-- Infos utilisateur -->
            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 10 0 25 5;">
                <StackPane>
                    <Circle fx:id="avatarCircle" fill="#3498db" radius="20" />
                    <Label fx:id="initialsLabel" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;" />
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="nameLabel" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px;" />
                    <Label fx:id="roleLabel" style="-fx-text-fill: #bdc3c7; -fx-font-size: 10px; -fx-text-transform: uppercase;" />
                </VBox>
            </HBox>

            <!-- Boutons de navigation -->
            <VBox spacing="6" VBox.vgrow="ALWAYS">
                <Button onAction="#switchToDashboard" minWidth="210" prefWidth="210" maxWidth="210" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-padding: 10 15; -fx-background-radius: 5;" text="Tableau de bord" onMouseEntered="#hoverEnter" onMouseExited="#hoverExit">
                    <graphic>
                        <SVGPath content="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" fill="white" scaleX="0.9" scaleY="0.9"/>
                    </graphic>
                </Button>
                <Button onAction="#switchToUsers" minWidth="210" prefWidth="210" maxWidth="210" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-padding: 10 15;" text="Utilisateurs" onMouseEntered="#hoverEnter" onMouseExited="#hoverExit">
                    <graphic>
                        <SVGPath content="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5s-3 1.34-3 3 1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z" fill="white" scaleX="0.9" scaleY="0.9"/>
                    </graphic>
                </Button>
                <Button onAction="#switchToAcademicStructure" minWidth="210" prefWidth="210" maxWidth="210" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-padding: 10 15;" text="Structure académique" onMouseEntered="#hoverEnter" onMouseExited="#hoverExit">
                    <graphic>
                        <SVGPath content="M12 7V3H2v18h20V7H12zM6 19H4v-2h2v2zm0-4H4v-2h2v2zm0-4H4V9h2v2zm0-4H4V5h2v2zm4 12H8v-2h2v2zm0-4H8v-2h2v2zm0-4H8V9h2v2zm0-4H8V5h2v2zm10 12h-2v-2h2v2zm0-4h-2v-2h2v2zm0-4h-2V9h2v2zm0-4h-2V5h2v2z" fill="white" scaleX="0.9" scaleY="0.9"/>
                    </graphic>
                </Button>
                <Button onAction="#switchToInstitutions" minWidth="210" prefWidth="210" maxWidth="210" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-padding: 10 15;" text="Établissements" onMouseEntered="#hoverEnter" onMouseExited="#hoverExit">
                    <graphic>
                        <SVGPath content="M12 7V3H2v18h20V7H12zM4 19V5h4v14H4zm14 0h-4V5h4v14zm-2-9h-2v2h2v-2zm-4 0H8v2h2v-2z" fill="white" scaleX="0.9" scaleY="0.9"/>
                    </graphic>
                </Button>
                <Button onAction="#switchToSupervision" minWidth="210" prefWidth="210" maxWidth="210" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-padding: 10 15;" text="Supervision" onMouseEntered="#hoverEnter" onMouseExited="#hoverExit">
                    <graphic>
                        <SVGPath content="M15 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm-9-2V7H4v3H1v2h3v3h2v-3h3v-2H6zm9 4c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" fill="white" scaleX="0.9" scaleY="0.9"/>
                    </graphic>
                </Button>
                <Button onAction="#switchToSystemConfig" minWidth="210" prefWidth="210" maxWidth="210" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-padding: 10 15;" text="Configuration système" onMouseEntered="#hoverEnter" onMouseExited="#hoverExit">
                    <graphic>
                        <SVGPath content="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z" fill="white" scaleX="0.9" scaleY="0.9"/>
                    </graphic>
                </Button>
            </VBox>

            <!-- Déconnexion -->
            <VBox alignment="BOTTOM_CENTER" style="-fx-padding: 20 0 0 0;">
                <Button alignment="CENTER" onAction="#handleLogout" minWidth="210" prefHeight="40.0" prefWidth="210.0" maxWidth="210"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="Déconnexion">
                    <graphic>
                        <SVGPath content="M13 3h-2v10h2V3zm4.83 2.17l-1.42 1.42C17.99 7.86 19 9.81 19 12c0 3.87-3.13 7-7 7s-7-3.13-7-7c0-2.19 1.01-4.14 2.58-5.42L6.17 5.17C4.23 6.82 3 9.26 3 12c0 4.97 4.03 9 9 9s9-4.03 9-9c0-2.74-1.23-5.18-3.17-6.83z" fill="white" scaleX="0.8" scaleY="0.8"/>
                    </graphic>
                </Button>
            </VBox>

        </VBox>
    </left>

    <center>
        <VBox spacing="0" VBox.vgrow="ALWAYS">
            <!-- Barre du haut -->
            <VBox style="-fx-background-color: #2c3e50;">
                <HBox style="-fx-padding: 15px 30px;" alignment="CENTER_LEFT" spacing="15">
                    <VBox spacing="2">
                        <Label text="Tableau de bord" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Espace superviseur – Gestion administrative" style="-fx-font-size: 11px; -fx-text-fill: #bdc3c7;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Zone de contenu -->
            <StackPane fx:id="contentPane" style="-fx-background-color: #ecf0f1;" VBox.vgrow="ALWAYS">
                <!-- Vue d'accueil par défaut -->
                <VBox fx:id="dashboardView" spacing="25" style="-fx-padding: 30px;">
                    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                        <VBox spacing="20" style="-fx-padding: 20;">
                            <Label text="Tableau de bord administrateur" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                            <Label text="Bienvenue dans l'espace superviseur. Utilisez le menu pour gérer les utilisateurs, la structure académique, les établissements, la supervision et la configuration du système." wrapText="true" style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d; -fx-max-width: 700;"/>
                            <VBox spacing="12" style="-fx-padding: 20; -fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);">
                                <Label text="Accès rapide" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <Label text="• Utilisateurs : gestion des comptes et rôles" wrapText="true" style="-fx-text-fill: #4a5568;"/>
                                <Label text="• Structure académique : universités, facultés, départements" wrapText="true" style="-fx-text-fill: #4a5568;"/>
                                <Label text="• Établissements : création et suivi des établissements" wrapText="true" style="-fx-text-fill: #4a5568;"/>
                                <Label text="• Supervision : journal des actions et suivi" wrapText="true" style="-fx-text-fill: #4a5568;"/>
                                <Label text="• Configuration système : paramètres de la plateforme" wrapText="true" style="-fx-text-fill: #4a5568;"/>
                            </VBox>
                        </VBox>
                    </ScrollPane>
                </VBox>
            </StackPane>
        </VBox>
    </center>
</BorderPane>
