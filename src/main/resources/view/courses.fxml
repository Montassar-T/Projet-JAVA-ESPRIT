<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.educlass.controller.CourseController"
            prefWidth="800" prefHeight="500">

    <!-- TOP SEARCH / FILTER BAR -->
    <top>
        <VBox spacing="10">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>

            <HBox spacing="10" alignment="CENTER_LEFT">

                <TextField fx:id="searchField"
                           promptText="Rechercher des cours..."
                           HBox.hgrow="ALWAYS"/>

                <Button text="Rechercher"
                        fx:id="searchBtn"
                        onAction="#onSearch"/>

                <Label text="Difficulté:"/>
                <ComboBox fx:id="levelFilter" prefWidth="130" promptText="Choisir un Difficulté"/>

                <Button text="Appliquer"
                        fx:id="applyFilterBtn"
                        onAction="#onApplyFilters"/>

                <Button text="Réinitialiser"
                        fx:id="resetFilterBtn"
                        onAction="#onResetFilters"/>

                <Pane HBox.hgrow="ALWAYS" />

                <Button text="Ajouter un cours"
                        fx:id="addCourseBtn"
                        onAction="#onAddCourse"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>

                <Button text="Supprimer la sélection"
                        fx:id="deleteSelectedBtn"
                        onAction="#onDeleteSelected"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;"/>

            </HBox>
        </VBox>
    </top>

    <!-- LIST CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" pannable="true">
            <content>
                <VBox fx:id="courseList"
                      spacing="15">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
