                    <VBox spacing="12" style="-fx-background-color: white; -fx-padding: 16px; -fx-border-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 2); -fx-pref-width: 400; -fx-min-height: 300; -fx-border-color: #ecf0f1; -fx-border-width: 1;">
                        <Label text="Designs &amp; Diagrams" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                        <ListView fx:id="designsListViewUnique" style="-fx-control-inner-background: #f8f9fa; -fx-font-size: 12px;" VBox.vgrow="ALWAYS" prefHeight="250"/>
                    </VBox>
                    <VBox spacing="12" style="-fx-background-color: white; -fx-padding: 16px; -fx-border-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 2); -fx-pref-width: 900; -fx-min-height: 300; -fx-border-color: #ecf0f1; -fx-border-width: 1;">
                        <Label text="Diagram Source / Preview" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                        <TextArea fx:id="designViewerAreaUnique" editable="false" wrapText="true" style="-fx-control-inner-background: #fafbfc; -fx-font-family: 'monospace'; -fx-font-size: 12px;" VBox.vgrow="ALWAYS" prefHeight="250"/>
                    </VBox>
                </HBox>
            </VBox>
            <!-- MY COURSES VIEW -->
            <VBox fx:id="myCoursesViewUnique" spacing="15" style="-fx-padding: 30px;">
                <HBox spacing="10">
                    <TextField fx:id="courseSearchField" promptText="Search courses..." style="-fx-padding: 8px; -fx-font-size: 12px;" HBox.hgrow="ALWAYS"/>
                    <Button text="🔍 Search" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
                </HBox>
                <ListView fx:id="coursesListView" style="-fx-control-inner-background: white; -fx-font-size: 12px; -fx-padding: 5px;" VBox.vgrow="ALWAYS"/>
            </VBox>
            <!-- ADD COURSE VIEW -->
            <VBox fx:id="addCourseViewUnique" spacing="15" style="-fx-padding: 30px;">
                <Label text="Add New Course" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                <GridPane hgap="15" vgap="15">
                    <Label text="Course Title:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="courseTitleField" GridPane.columnIndex="1" GridPane.rowIndex="0" HBox.hgrow="ALWAYS"/>
                    <Label text="Description:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextArea fx:id="courseDescField" prefHeight="80" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <Label text="Level:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <ComboBox fx:id="courseLevelCombo" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    <Label text="Duration (hours):" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <TextField fx:id="courseDurationField" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                </GridPane>
                <HBox spacing="10">
                    <Button text="Save Course" style="-fx-background-color: #27ae60; -fx-text-fill: white;" onAction="#handleSaveCourse"/>
                    <Button text="Cancel" style="-fx-background-color: #95a5a6; -fx-text-fill: white;" onAction="#handleCancelCourse"/>
                </HBox>
            </VBox>
            <!-- MY LESSONS VIEW -->
            <VBox fx:id="myLessonsViewUnique" spacing="15" style="-fx-padding: 30px;">
                <HBox spacing="10">
                    <TextField fx:id="lessonSearchField" promptText="Search lessons..." style="-fx-padding: 8px; -fx-font-size: 12px;" HBox.hgrow="ALWAYS"/>
                    <Button text="🔍 Search" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
                </HBox>
                <ListView fx:id="lessonsListView" style="-fx-control-inner-background: white; -fx-font-size: 12px; -fx-padding: 5px;" VBox.vgrow="ALWAYS"/>
            </VBox>
            <!-- ADD LESSON VIEW -->
            <VBox fx:id="addLessonViewUnique" spacing="15" style="-fx-padding: 30px;">
                <Label text="Add New Lesson" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                <GridPane hgap="15" vgap="15">
                    <Label text="Lesson Title:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="lessonTitleField" GridPane.columnIndex="1" GridPane.rowIndex="0" HBox.hgrow="ALWAYS"/>
                    <Label text="Course:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <ComboBox fx:id="lessonCourseCombo" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <Label text="Content:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <TextArea fx:id="lessonContentArea" prefHeight="150" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    <Label text="Duration (minutes):" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <TextField fx:id="lessonDurationField" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                </GridPane>
                <HBox spacing="10">
                    <Button text="Save Lesson" style="-fx-background-color: #27ae60; -fx-text-fill: white;" onAction="#handleSaveLesson"/>
                    <Button text="Cancel" style="-fx-background-color: #95a5a6; -fx-text-fill: white;" onAction="#handleCancelLesson"/>
                </HBox>
            </VBox>
            <!-- MY QUESTIONS VIEW -->
            <VBox fx:id="myQuestionsViewUnique" spacing="15" style="-fx-padding: 30px;">
                <HBox spacing="10">
                    <TextField fx:id="questionSearchField" promptText="Search questions..." style="-fx-padding: 8px; -fx-font-size: 12px;" HBox.hgrow="ALWAYS"/>
                    <Button text="🔍 Search" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
                </HBox>
                <ListView fx:id="questionsListView" style="-fx-control-inner-background: white; -fx-font-size: 12px; -fx-padding: 5px;" VBox.vgrow="ALWAYS"/>
            </VBox>
            <!-- ADD QUESTION VIEW -->
            <VBox fx:id="addQuestionViewUnique" spacing="15" style="-fx-padding: 30px;">
                <Label text="Add New Question" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                <GridPane hgap="15" vgap="15">
                    <Label text="Question Text:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextArea fx:id="questionTextField" prefHeight="100" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <Label text="Question Type:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <ComboBox fx:id="questionTypeCombo" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <Label text="Course:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <ComboBox fx:id="questionCourseCombo" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    <Label text="Difficulty:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <ComboBox fx:id="questionDifficultyCombo" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                </GridPane>
                <HBox spacing="10">
                    <Button text="Save Question" style="-fx-background-color: #27ae60; -fx-text-fill: white;" onAction="#handleSaveQuestion"/>
                    <Button text="Cancel" style="-fx-background-color: #95a5a6; -fx-text-fill: white;" onAction="#handleCancelQuestion"/>
                </HBox>
            </VBox>
            <!-- MY STUDENTS VIEW -->
            <VBox fx:id="myStudentsViewUnique" spacing="15" style="-fx-padding: 30px;">
                <HBox spacing="10">
                    <TextField fx:id="studentSearchField" promptText="Search students..." style="-fx-padding: 8px; -fx-font-size: 12px;" HBox.hgrow="ALWAYS"/>
                    <Button text="🔍 Search" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
                </HBox>
                <ListView fx:id="studentsListView" style="-fx-control-inner-background: white; -fx-font-size: 12px; -fx-padding: 5px;" VBox.vgrow="ALWAYS"/>
            </VBox>
            <!-- ADD STUDENT VIEW -->
            <VBox fx:id="addStudentViewUnique" spacing="15" style="-fx-padding: 30px;">
                <Label text="Add Student" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                <GridPane hgap="15" vgap="15">
                    <Label text="Student Name:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="studentNameField" GridPane.columnIndex="1" GridPane.rowIndex="0" HBox.hgrow="ALWAYS"/>
                    <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="studentEmailField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <Label text="Course:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <ComboBox fx:id="studentCourseCombo" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    <Label text="Status:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <ComboBox fx:id="studentStatusCombo" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                </GridPane>
                <HBox spacing="10">
                    <Button text="Add Student" style="-fx-background-color: #27ae60; -fx-text-fill: white;" onAction="#handleAddStudent"/>
                    <Button text="Cancel" style="-fx-background-color: #95a5a6; -fx-text-fill: white;" onAction="#handleCancelStudent"/>
                </HBox>
            </VBox>
            <!-- GRADES VIEW -->
            <VBox fx:id="gradesViewUnique" spacing="15" style="-fx-padding: 30px;">
                <HBox spacing="10">
                    <ComboBox fx:id="gradesFilterCombo" promptText="Filter by..." style="-fx-padding: 8px; -fx-font-size: 12px;" prefWidth="150"/>
                    <TextField fx:id="gradesSearchField" promptText="Search..." style="-fx-padding: 8px; -fx-font-size: 12px;" HBox.hgrow="ALWAYS"/>
                </HBox>
                <TableView fx:id="gradesTableView" style="-fx-font-size: 12px;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn text="Student" prefWidth="150"/>
                        <TableColumn text="Course" prefWidth="150"/>
                        <TableColumn text="Grade" prefWidth="100"/>
                        <TableColumn text="Status" prefWidth="100"/>
                    </columns>
                </TableView>
            </VBox>
            <!-- EVALUATIONS VIEW -->
            <VBox fx:id="evaluationsViewUnique" spacing="15" style="-fx-padding: 30px;">
                <HBox spacing="10">
                    <TextField fx:id="evaluationSearchField" promptText="Search evaluations..." style="-fx-padding: 8px; -fx-font-size: 12px;" HBox.hgrow="ALWAYS"/>
                    <Button text="🔍 Search" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
                </HBox>
                <ListView fx:id="evaluationsListView" style="-fx-control-inner-background: white; -fx-font-size: 12px; -fx-padding: 5px;" VBox.vgrow="ALWAYS"/>
            </VBox>
            <!-- SETTINGS VIEW -->
            <VBox fx:id="settingsViewUnique" spacing="15" style="-fx-padding: 30px;">
                <Label text="Teacher Settings" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                <GridPane hgap="15" vgap="15">
                    <Label text="Full Name:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="settingsNameField" GridPane.columnIndex="1" GridPane.rowIndex="0" HBox.hgrow="ALWAYS"/>
                    <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="settingsEmailField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <Label text="Department:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <TextField fx:id="settingsDepartmentField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    <Label text="Bio:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <TextArea fx:id="settingsBioArea" prefHeight="100" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                </GridPane>
                <HBox spacing="10">
                    <Button text="Save Settings" style="-fx-background-color: #27ae60; -fx-text-fill: white;" onAction="#handleSaveSettings"/>
                    <Button text="Change Password" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
                </HBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
